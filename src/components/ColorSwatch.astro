---
interface Props {
  role?: string;
  roles?: string[];
  table?: boolean;
}
const { role, roles, table = true } = Astro.props;
const roleList = roles ?? (role ? [role] : []);
---

{
  roleList.length > 0 && (
    <div class="swatch-grid">
      {roleList.map((r) => (
        <div class="swatch-tile" data-swatch-role={r}>
          <div
            class="swatch-preview"
            style={`background: var(--color-${r});`}
          />
          <div class="swatch-info">
            <code class="swatch-name">--color-{r}</code>
            <span
              class="swatch-value"
              data-token-value={`--color-${r}`}
              aria-label={`OKLCH value for --color-${r}`}
            >
              —
            </span>
          </div>
        </div>
      ))}
    </div>
  )
}

{
  table && roleList.length > 0 && (
    <table class="swatch-table">
      <thead>
        <tr>
          <th>Token</th>
          <th>Value</th>
        </tr>
      </thead>
      <tbody>
        {roleList.map((r) => (
          <tr>
            <td>
              <code>--color-{r}</code>
            </td>
            <td>
              <span data-token-value={`--color-${r}`}>—</span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )
}

<script>
  import { populateValues, watchThemeChanges } from "~/scripts/visuals";
  populateValues(document);
  watchThemeChanges(() => populateValues(document));
</script>

<style>
  .swatch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(9rem, 1fr));
    gap: 0.75rem;
    margin-block: 1.5rem;
  }

  .swatch-tile {
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid var(--sl-color-gray-5);
  }

  .swatch-preview {
    height: 4rem;
  }

  /* Striped pattern when token is unresolved */
  .swatch-preview:has(+ .swatch-info [data-missing]) {
    background: repeating-linear-gradient(
      45deg,
      oklch(90% 0 0),
      oklch(90% 0 0) 4px,
      oklch(70% 0 0) 4px,
      oklch(70% 0 0) 8px
    ) !important;
  }

  .swatch-info {
    padding: 0.5rem 0.625rem;
  }

  .swatch-name {
    display: block;
    font-size: 0.7rem;
    word-break: break-all;
    color: var(--sl-color-gray-2);
  }

  .swatch-value {
    display: block;
    font-size: 0.65rem;
    color: var(--sl-color-gray-3);
    margin-top: 0.2rem;
    font-family: var(--sl-font-system-mono);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .swatch-table {
    margin-block-start: 0.5rem;
    font-size: 0.85rem;
    width: 100%;
  }

  .swatch-table th {
    text-align: start;
    font-weight: 600;
    padding-block: 0.25rem;
  }

  .swatch-table td {
    padding-block: 0.2rem;
    vertical-align: middle;
  }
</style>
